# ============================================================
# .gitignore — SisConfec
# ============================================================

# Dependências
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.output/
out/

# Variáveis de ambiente (NUNCA commitar!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Cache
.cache/
.parcel-cache/
.vite/
.turbo/

# Editores
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Testes
coverage/
.nyc_output/

# Python (scripts auxiliares de deploy)
__pycache__/
*.py[cod]
*.pyo
.venv/

# Supabase local
supabase/.branches/
supabase/.temp/

# Claude Code internal (settings locais, não devem ir ao repo)
.claude/

# Scripts de deploy com tokens embutidos (use vars de ambiente em produção)
database/apply_schema.py
database/apply_rls.py
database/apply_rls_fix.py
database/apply-schema.sh
